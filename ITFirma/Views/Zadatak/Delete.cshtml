@model ITFirma.Models.Zadatak

@{
    ViewData["Title"] = "Obriši zadatak";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Zadaci</a></li>
        <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.Id">@Model.Naziv</a></li>
        <li class="breadcrumb-item active">Obriši</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white fw-semibold">
                Potvrdi brisanje
            </div>
            <div class="card-body">
                <p>Da li ste sigurni da želite obrisati zadatak <strong>@Model.Naziv</strong>?</p>

                <ul class="list-unstyled mb-4">
                    <li><span class="text-muted">Projekat:</span> @Model.Projekat?.Naziv</li>
                    <li><span class="text-muted">Rok:</span> @Model.Rok.ToString("dd.MM.yyyy")</li>
                    <li>
                        <span class="text-muted">Status:</span>
                        @{
                            var zBadge = Model.Status switch
                            {
                                ITFirma.Models.StatusZadatka.UToku   => "bg-primary",
                                ITFirma.Models.StatusZadatka.Zavrsen => "bg-success",
                                _                                     => "bg-secondary",
                            };
                        }
                        <span class="badge @zBadge">@Model.Status</span>
                    </li>
                </ul>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Da, obriši</button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Odustani</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
