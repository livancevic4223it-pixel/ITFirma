@model IEnumerable<ITFirma.Models.Zadatak>

@{
    ViewData["Title"] = "Zadaci";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">Zadaci</h2>
    <a asp-action="Create" class="btn btn-primary">+ Novi zadatak</a>
</div>

@if (TempData["Success"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["Success"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Any())
{
    <div class="alert alert-info">Nema unesenih zadataka.</div>
}
else
{
    @* Dropdown filter po statusu — iznad DataTables kontrola *@
    <div class="mb-2 d-flex align-items-center gap-2">
        <label for="statusFilter" class="form-label mb-0 fw-semibold">Filter po statusu:</label>
        <select id="statusFilter" class="form-select form-select-sm w-auto">
            <option value="">— Svi statusi —</option>
            <option value="Otvoren">Otvoren</option>
            <option value="UToku">UToku</option>
            <option value="Zavrsen">Zavrsen</option>
        </select>
    </div>

    <div class="table-responsive">
        <table id="tblZadaci" class="table table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Naziv</th>
                    <th>Projekat</th>
                    <th>Rok</th>
                    <th>Status</th>
                    <th class="text-end">Akcije</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var z in Model)
                {
                    var zBadge = z.Status switch
                    {
                        ITFirma.Models.StatusZadatka.UToku   => "bg-primary",
                        ITFirma.Models.StatusZadatka.Zavrsen => "bg-success",
                        _                                     => "bg-secondary",
                    };
                    var rokCss = (z.Rok < DateTime.Today && z.Status != ITFirma.Models.StatusZadatka.Zavrsen)
                                 ? "text-danger fw-semibold" : "";
                    <tr>
                        <td>
                            <a asp-action="Details" asp-route-id="@z.Id" class="fw-semibold text-decoration-none">
                                @z.Naziv
                            </a>
                        </td>
                        <td>
                            <a asp-controller="Projekat" asp-action="Details" asp-route-id="@z.ProjekatId"
                               class="text-decoration-none text-muted">
                                @z.Projekat?.Naziv
                            </a>
                        </td>
                        <td class="@rokCss">@z.Rok.ToString("dd.MM.yyyy")</td>
                        @* data-status za tačno podudaranje u filteru *@
                        <td data-status="@z.Status">
                            <span class="badge @zBadge">@z.Status</span>
                        </td>
                        <td class="text-end">
                            <a asp-action="Details" asp-route-id="@z.Id" class="btn btn-sm btn-outline-secondary">Detalji</a>
                            <a asp-action="Edit"    asp-route-id="@z.Id" class="btn btn-sm btn-outline-primary">Uredi</a>
                            <a asp-action="Delete"  asp-route-id="@z.Id" class="btn btn-sm btn-outline-danger">Obriši</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
<script>
$(function () {
    var table = $('#tblZadaci').DataTable({
        language: {
            search:        "Pretraži:",
            lengthMenu:    "Prikaži _MENU_ zapisa",
            info:          "Prikazano _START_–_END_ od _TOTAL_ zapisa",
            infoEmpty:     "Nema zapisa",
            infoFiltered:  "(filtrirano od _MAX_ ukupno)",
            zeroRecords:   "Nema rezultata",
            paginate: {
                first:    "Prva",
                last:     "Poslednja",
                next:     "Sledeća",
                previous: "Prethodna"
            }
        },
        pageLength: 10,
        order: [[2, 'asc']],  // sortiraj po Roku
        columnDefs: [
            // Projekat — isključen iz pretrage (pretraga samo po Nazivu)
            { targets: 1, searchable: false },
            // Rok — isključen iz pretrage
            { targets: 2, searchable: false },
            // Akcije — bez sortiranja i pretrage
            { targets: 4, orderable: false, searchable: false }
        ]
    });

    // Dropdown filter po statusu — filtrira kolonu 3
    $('#statusFilter').on('change', function () {
        var val = $(this).val();
        // Pretraži po data-status atributu — tačno podudaranje
        if (val === '') {
            table.column(3).search('').draw();
        } else {
            // Koristimo regex s ^ i $ za tačno podudaranje teksta ćelije
            table.column(3).search('^' + val + '$', true, false).draw();
        }
    });
});
</script>
}
