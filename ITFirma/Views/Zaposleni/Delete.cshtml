@model ITFirma.Models.Zaposleni

@{
    ViewData["Title"] = "Obriši zaposlenog";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Zaposleni</a></li>
        <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.Id">@Model.PunoIme</a></li>
        <li class="breadcrumb-item active">Obriši</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white fw-semibold">
                Potvrdi brisanje
            </div>
            <div class="card-body">
                <p>Da li ste sigurni da želite obrisati zaposlenog <strong>@Model.PunoIme</strong>?</p>

                @if (Model.Angazovanja.Any())
                {
                    <div class="alert alert-warning mb-3">
                        <strong>Upozorenje:</strong> Zaposleni je aktivan na @Model.Angazovanja.Count projektu/projekata.
                        Brisanjem zaposlenog uklanjaju se i sva angažovanja.
                    </div>
                }

                <ul class="list-unstyled mb-4">
                    <li><span class="text-muted">Pozicija:</span> @Model.Pozicija</li>
                    <li><span class="text-muted">Email:</span> @Model.Email</li>
                    <li><span class="text-muted">Angažovanja:</span> @Model.Angazovanja.Count</li>
                </ul>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger">Da, obriši</button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Odustani</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
