@model ITFirma.Models.Klijent

<div class="card h-100">
    <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
        Klijent
        <a asp-controller="Klijent" asp-action="Details" asp-route-id="@Model.Id"
           class="btn btn-sm btn-outline-secondary">Profil</a>
    </div>
    <ul class="list-group list-group-flush">
        <li class="list-group-item">
            <span class="text-muted small">Naziv</span><br />
            <a asp-controller="Klijent" asp-action="Details" asp-route-id="@Model.Id"
               class="fw-semibold text-decoration-none">
                @Model.Naziv
            </a>
        </li>
        <li class="list-group-item">
            <span class="text-muted small">Email</span><br />
            <a href="mailto:@Model.Email" class="text-decoration-none">@Model.Email</a>
        </li>
        <li class="list-group-item">
            <span class="text-muted small">Telefon</span><br />
            @(string.IsNullOrWhiteSpace(Model.Telefon) ? "—" : Model.Telefon)
        </li>
        <li class="list-group-item">
            <span class="text-muted small">Adresa</span><br />
            @(string.IsNullOrWhiteSpace(Model.Adresa) ? "—" : Model.Adresa)
        </li>
    </ul>
</div>
