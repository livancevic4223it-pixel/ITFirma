@model ITFirma.Models.Klijent

@{
    ViewData["Title"] = Model.Naziv;
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Klijenti</a></li>
        <li class="breadcrumb-item active">@Model.Naziv</li>
    </ol>
</nav>

<div class="d-flex justify-content-between align-items-start mb-4">
    <h2 class="mb-0">@Model.Naziv</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-outline-primary">Uredi</a>
        <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-outline-danger ms-1">Obriši</a>
    </div>
</div>

<div class="row g-4">
    <div class="col-md-5">
        <div class="card">
            <div class="card-header fw-semibold">Podaci o klijentu</div>
            <ul class="list-group list-group-flush">
                <li class="list-group-item">
                    <span class="text-muted small">Email</span><br />
                    <a href="mailto:@Model.Email">@Model.Email</a>
                </li>
                <li class="list-group-item">
                    <span class="text-muted small">Telefon</span><br />
                    @(Model.Telefon ?? "—")
                </li>
                <li class="list-group-item">
                    <span class="text-muted small">Adresa</span><br />
                    @(Model.Adresa ?? "—")
                </li>
            </ul>
        </div>
    </div>

    <div class="col-md-7">
        <div class="card">
            <div class="card-header fw-semibold d-flex justify-content-between align-items-center">
                Projekti
                <span class="badge bg-secondary">@Model.Projekti.Count</span>
            </div>
            @if (!Model.Projekti.Any())
            {
                <div class="card-body text-muted">Nema projekata za ovog klijenta.</div>
            }
            else
            {
                <ul class="list-group list-group-flush">
                    @foreach (var p in Model.Projekti.OrderByDescending(x => x.DatumPocetka))
                    {
                        <li class="list-group-item d-flex justify-content-between align-items-center">
                            <div>
                                <a asp-controller="Projekat" asp-action="Details" asp-route-id="@p.Id"
                                   class="fw-semibold text-decoration-none">@p.Naziv</a>
                                <div class="text-muted small">
                                    @p.DatumPocetka.ToString("dd.MM.yyyy")
                                    @if (p.DatumZavrsetka.HasValue)
                                    {
                                        <span> – @p.DatumZavrsetka.Value.ToString("dd.MM.yyyy")</span>
                                    }
                                </div>
                            </div>
                            @{
                                var badgeClass = p.Status switch
                                {
                                    ITFirma.Models.StatusProjekta.UToku    => "bg-primary",
                                    ITFirma.Models.StatusProjekta.Zavrsen  => "bg-success",
                                    ITFirma.Models.StatusProjekta.Otkazan  => "bg-danger",
                                    _                                       => "bg-secondary",
                                };
                            }
                            <span class="badge @badgeClass">@p.Status</span>
                        </li>
                    }
                </ul>
            }
        </div>
    </div>
</div>

<div class="mt-3">
    <a asp-action="Index" class="btn btn-outline-secondary">← Nazad na listu</a>
</div>
