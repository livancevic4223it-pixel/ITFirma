@model ITFirma.Models.Klijent

@{
    ViewData["Title"] = "Novi klijent";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Klijenti</a></li>
        <li class="breadcrumb-item active">Novi klijent</li>
    </ol>
</nav>

<h2 class="mb-4">Novi klijent</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

            <div class="mb-3">
                <label asp-for="Naziv" class="form-label"></label>
                <input asp-for="Naziv" class="form-control" placeholder="Naziv kompanije" />
                <span asp-validation-for="Naziv" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" placeholder="info@kompanija.com" />
                <span asp-validation-for="Email" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Telefon" class="form-label"></label>
                <input asp-for="Telefon" class="form-control" placeholder="+387 33 000 000" />
                <span asp-validation-for="Telefon" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Adresa" class="form-label"></label>
                <input asp-for="Adresa" class="form-control" placeholder="Ulica i broj, Grad" />
                <span asp-validation-for="Adresa" class="text-danger small"></span>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Sačuvaj</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Odustani</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
