@model ITFirma.Models.Klijent

@{
    ViewData["Title"] = "Obriši klijenta";
}

<nav aria-label="breadcrumb" class="mb-3">
    <ol class="breadcrumb">
        <li class="breadcrumb-item"><a asp-action="Index">Klijenti</a></li>
        <li class="breadcrumb-item"><a asp-action="Details" asp-route-id="@Model.Id">@Model.Naziv</a></li>
        <li class="breadcrumb-item active">Obriši</li>
    </ol>
</nav>

<div class="row">
    <div class="col-md-6">
        <div class="card border-danger">
            <div class="card-header bg-danger text-white fw-semibold">
                Potvrdi brisanje
            </div>
            <div class="card-body">
                <p>Da li ste sigurni da želite obrisati klijenta <strong>@Model.Naziv</strong>?</p>

                @if (Model.Projekti.Any())
                {
                    <div class="alert alert-warning mb-3">
                        <strong>Upozorenje:</strong> Ovaj klijent ima @Model.Projekti.Count projekat(a).
                        Brisanje klijenta nije moguće dok postoje vezani projekti.
                    </div>
                }

                <ul class="list-unstyled mb-4">
                    <li><span class="text-muted">Email:</span> @Model.Email</li>
                    <li><span class="text-muted">Telefon:</span> @(Model.Telefon ?? "—")</li>
                    <li><span class="text-muted">Adresa:</span> @(Model.Adresa ?? "—")</li>
                </ul>

                <form asp-action="Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-danger"
                                @(Model.Projekti.Any() ? "disabled" : "")>
                            Da, obriši
                        </button>
                        <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Odustani</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
