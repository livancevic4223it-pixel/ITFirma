@{
    ViewData["Title"] = "IT Firma";
}

<div class="text-center mb-5">
    <h1 class="display-4 fw-bold">IT Firma</h1>
    <p class="text-muted">Sistem za upravljanje IT agencijom</p>
</div>

<div class="row g-4 justify-content-center mb-4">
    <div class="col-sm-6 col-lg-3">
        <div class="card text-white bg-primary h-100 shadow-sm">
            <div class="card-body text-center py-4">
                <div class="display-5 fw-bold">@ViewBag.BrojKlijenata</div>
                <div class="mt-1">Klijenata</div>
            </div>
            <div class="card-footer text-center bg-primary border-0">
                <a asp-controller="Klijent" asp-action="Index" class="text-white text-decoration-none small">
                    Pregledaj →
                </a>
            </div>
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card text-white bg-success h-100 shadow-sm">
            <div class="card-body text-center py-4">
                <div class="display-5 fw-bold">@ViewBag.BrojProjekata</div>
                <div class="mt-1">Projekata</div>
            </div>
            @if (User.Identity!.IsAuthenticated)
            {
                <div class="card-footer text-center bg-success border-0">
                    <a asp-controller="Projekat" asp-action="Index" class="text-white text-decoration-none small">
                        Pregledaj →
                    </a>
                </div>
            }
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card text-white bg-info h-100 shadow-sm">
            <div class="card-body text-center py-4">
                <div class="display-5 fw-bold">@ViewBag.BrojZaposlenih</div>
                <div class="mt-1">Zaposlenih</div>
            </div>
            @if (User.Identity!.IsAuthenticated)
            {
                <div class="card-footer text-center bg-info border-0">
                    <a asp-controller="Zaposleni" asp-action="Index" class="text-white text-decoration-none small">
                        Pregledaj →
                    </a>
                </div>
            }
        </div>
    </div>

    <div class="col-sm-6 col-lg-3">
        <div class="card text-white bg-warning h-100 shadow-sm">
            <div class="card-body text-center py-4">
                <div class="display-5 fw-bold">@ViewBag.BrojZadataka</div>
                <div class="mt-1">Zadataka</div>
            </div>
            @if (User.Identity!.IsAuthenticated)
            {
                <div class="card-footer text-center bg-warning border-0">
                    <a asp-controller="Zadatak" asp-action="Index" class="text-white text-decoration-none small">
                        Pregledaj →
                    </a>
                </div>
            }
        </div>
    </div>
</div>

@if (!User.Identity!.IsAuthenticated)
{
    <div class="text-center mt-4">
        <a asp-controller="Account" asp-action="Login" class="btn btn-primary btn-lg">
            Prijavi se
        </a>
    </div>
}
